# =============================================================================
# A360 Agent Manager — Environment Variables
# Copy to .env.local and fill in real values
# =============================================================================

# --- Agent Manager Supabase (agent definitions, tools, runs, documents) -----
NEXT_PUBLIC_AGENT_SUPABASE_URL=https://aejskvmpembryunnbgrk.supabase.co
AGENT_SUPABASE_SERVICE_KEY=sb_secret_...

# --- CMS Supabase (vectorized content: podcasts, YouTube, PubMed, industry) -
NEXT_PUBLIC_CMS_SUPABASE_URL=https://gjqicqldjgvrwmtkliie.supabase.co
CMS_SUPABASE_SERVICE_KEY=sb_secret_...

# --- Prompt Runner Supabase (transcripts, extraction runs) ------------------
NEXT_PUBLIC_PR_SUPABASE_URL=https://ksutsaiogmicgaarocba.supabase.co
PR_SUPABASE_SERVICE_KEY=sb_secret_...

# --- Prompt Runner API (Railway) --------------------------------------------
NEXT_PUBLIC_PROMPT_RUNNER_URL=https://prompt-runner-production.up.railway.app
PROMPT_RUNNER_API_KEY=

# --- LLM Providers (for playground / agent testing) -------------------------
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# --- Vercel AI Gateway (Research/Evidence tab generation) --------------------
# Required by @ai-sdk/gateway for the /api/research/chat route. Without it,
# streamText throws GatewayAuthenticationError at runtime.
AI_GATEWAY_API_KEY=

# --- Beta access gate -------------------------------------------------------
# Shared access code for invite-only beta. Leave unset to disable the gate.
BETA_ACCESS_PASSWORD=
# App mode: "internal" (full app) or "demo" (acquirer-facing: hides + 404s the
# studio/builder surfaces — Agent Manager, agent/tool/playground APIs).
NEXT_PUBLIC_APP_MODE=internal
