# =============================================================================
# A360 Agent Manager — Environment Variables
# Copy to .env.local and fill in real values
# =============================================================================

# --- Agent Manager Supabase (agent definitions, tools, runs, documents) -----
NEXT_PUBLIC_AGENT_SUPABASE_URL=https://aejskvmpembryunnbgrk.supabase.co
AGENT_SUPABASE_SERVICE_KEY=sb_secret_...

# --- CMS Supabase (vectorized content: podcasts, YouTube, PubMed, industry) -
NEXT_PUBLIC_CMS_SUPABASE_URL=https://gjqicqldjgvrwmtkliie.supabase.co
CMS_SUPABASE_SERVICE_KEY=sb_secret_...

# --- PR Supabase REMOVED 2026-06-14 (accessed via HTTP API, not direct) ----

# --- Ops Store Supabase (patients, consultations, extractions, agent outputs) -
# Project: uedajrdzcjfrmbiznflf — server-side only (service role key).
OPS_SUPABASE_URL=https://uedajrdzcjfrmbiznflf.supabase.co
OPS_SUPABASE_SERVICE_KEY=<service_role key from Supabase dashboard>

# --- Agent Service (Python FastAPI — cached workflow results) ----------------
AGENT_SERVICE_URL=http://127.0.0.1:8000

# --- RAG Search Service (deployed to Railway — WS-B) -------------------------
RAG_SEARCH_URL=https://search-api-production-2fc0.up.railway.app

# --- Prompt Runner API (Railway — legacy, being replaced by ops store) -------
NEXT_PUBLIC_PROMPT_RUNNER_URL=https://prompt-runner-production.up.railway.app
PROMPT_RUNNER_API_KEY=

# --- LLM Providers (for playground / agent testing) -------------------------
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# --- Vercel AI Gateway (Research/Evidence tab generation) --------------------
# Required by @ai-sdk/gateway for the /api/research/chat route. Without it,
# streamText throws GatewayAuthenticationError at runtime.
AI_GATEWAY_API_KEY=

# --- Beta access gate -------------------------------------------------------
# Shared access code for invite-only beta. Leave unset to disable the gate.
BETA_ACCESS_PASSWORD=
# App mode: "internal" (full app) or "demo" (acquirer-facing: hides + 404s the
# studio/builder surfaces — Agent Manager, agent/tool/playground APIs).
NEXT_PUBLIC_APP_MODE=internal

# --- Embed surface (/embed/*) -----------------------------------------------
# Comma-separated origins allowed to iframe /embed/* routes.
# Add Boulevard staging/prod domains when deploying.
# Example: EMBED_ALLOWED_ORIGINS=http://localhost:3000,https://boulevard-staging.example.com,https://boulevard.example.com
EMBED_ALLOWED_ORIGINS=http://localhost:3000
# Same origins for client-side postMessage targetOrigin validation (bridge.ts).
# Must match EMBED_ALLOWED_ORIGINS so the bridge accepts/sends messages correctly.
NEXT_PUBLIC_EMBED_PARENT_ORIGINS=http://localhost:3000
